# ── Anthropic API ─────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: point at a local OpenAI-compatible gateway (e.g. LiteLLM, OpenRouter)
# Leave commented out to use Anthropic directly.
# ANTHROPIC_BASE_URL=http://127.0.0.1:8080

# ── AI Models ─────────────────────────────────────────────────────────────────
# Vision model for photo culling (must support image input)
CULL_MODEL=claude-sonnet-4-6

# Text model for narrative writing (any Claude model works)
NARRATIVE_MODEL=claude-sonnet-4-6

# ── App Auth ──────────────────────────────────────────────────────────────────
# Login credentials for the web UI (change these!)
APP_USERNAME=admin
APP_PASSWORD=changeme

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# ── WordPress Publishing (optional) ───────────────────────────────────────────
# Leave blank to disable WP publishing features.
# WP_APP_PASSWORD uses a WordPress Application Password (not your login password).
# Generate one at: WordPress Admin → Users → Profile → Application Passwords
WP_URL=https://your-wordpress-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
